# Database
DATABASE_URL=postgresql://rendly_user:rendly_password@localhost:5432/rendly_prod
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# Redis
REDIS_URL=redis://localhost:6379

# OAuth
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# JWT
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your_refresh_token_secret
REFRESH_TOKEN_EXPIRES_IN=30d

# Frontend (optional - defaults work for local dev)
# Auth and /api/users: auto-detects 4001 or 80
NEXT_PUBLIC_API_URL=http://localhost:8080
# Chat REST (conversations, messages): defaults try 4002 then 3004
NEXT_PUBLIC_CHAT_API_URL=http://localhost:4002
# CCS WebSocket (Socket.IO): defaults to ws://localhost:3004
NEXT_PUBLIC_CCS_WS_URL=ws://localhost:3004

# Moderation
OPENAI_API_KEY=your_openai_api_key

# Services Ports
AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
MATCHING_SERVICE_PORT=3003
CHAT_SERVICE_PORT=3004
VIDEO_SERVICE_PORT=3005
MODERATION_SERVICE_PORT=3006
HUDDLE_SERVICE_PORT=3007
ADMIN_SERVICE_PORT=3008

# Environment
NODE_ENV=development
