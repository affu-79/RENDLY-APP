{
  "name": "rendly-backend",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "services/*",
    "shared"
  ],
  "scripts": {
    "dev": "lerna run dev --parallel",
    "dev:auth": "npm run dev --workspace=auth-service",
    "free-port:auth": "powershell -Command \"Get-NetTCPConnection -LocalPort 4001 -ErrorAction SilentlyContinue | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force -ErrorAction SilentlyContinue }\"",
    "free-ports": "powershell -Command \"@(4001) | ForEach-Object { Get-NetTCPConnection -LocalPort $_ -ErrorAction SilentlyContinue | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force -ErrorAction SilentlyContinue } }\"",
    "build": "lerna run build",
    "start": "lerna run start --parallel",
    "test": "lerna run test",
    "lint": "lerna run lint",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "db:migrate": "npm run migrate --workspace=user-service"
  },
  "devDependencies": {
    "lerna": "^7.4.0",
    "typescript": "^5.3.0",
    "ts-node": "^10.9.0",
    "nodemon": "^3.0.0",
    "@types/node": "^20.0.0",
    "prettier": "^3.1.0",
    "eslint": "^8.52.0"
  }
}
