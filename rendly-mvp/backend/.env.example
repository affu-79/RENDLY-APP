# Copy to .env and fill in. Single file for all backend services (Docker + local).

# === Shared ===
NODE_ENV=development
REDIS_URL=redis://localhost:6379

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: direct Postgres for chat appends (avoids 57014). Use the pooler URI from Supabase Dashboard -> Settings -> Database (Transaction or Session mode). Do not use db.REF.supabase.co if you see "Tenant or user not found".
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# === Service ports ===
# Auth (login, JWT, OAuth) - frontend uses this for /api/auth and /api/users
AUTH_SERVICE_PORT=4001
USER_SERVICE_PORT=3002
MATCHING_SERVICE_PORT=3003
VIDEO_SERVICE_PORT=3005
MODERATION_SERVICE_PORT=3006
HUDDLE_SERVICE_PORT=3007
ADMIN_SERVICE_PORT=3008

# === Auth service ===
JWT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Password reset email (SMTP). If not set, reset link is only logged (dev).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
APP_NAME=Rendly

# === Moderation service ===
OPENAI_API_KEY=
