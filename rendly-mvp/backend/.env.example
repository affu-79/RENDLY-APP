# Copy to .env and fill in. Single file for all backend services (Docker + local).

# === Shared ===
NODE_ENV=development
REDIS_URL=redis://localhost:6379

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Service ports ===
AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
MATCHING_SERVICE_PORT=3003
CCS_SERVICE_PORT=3004
CHAT_SERVICE_PORT=3004
VIDEO_SERVICE_PORT=3005
MODERATION_SERVICE_PORT=3006
HUDDLE_SERVICE_PORT=3007
ADMIN_SERVICE_PORT=3008

# === Auth service ===
JWT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# === Moderation service ===
OPENAI_API_KEY=
